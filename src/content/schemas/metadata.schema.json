{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Content Metadata",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "author": { "type": "string" },
    "license": { "type": "string" }
  }
}
